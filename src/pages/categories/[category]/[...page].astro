---
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'
import { POSTS_CONFIG } from '~/config'
import Layout from '~/layouts/Layout.astro'
import Pagination from '~/components/base/Pagination.astro'
import List from '~/components/posts/card/List.astro'
import { getAllPosts, getAllCategories } from '~/lib/data'

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const [allPosts, categoriesMap] = await Promise.all([getAllPosts(), getAllCategories()])

  const uniqueCategories = Object.keys(categoriesMap)

  return uniqueCategories
    .map((category) => {
      const categoryPosts = allPosts.filter((post) => post.data.category === category)
      return paginate(categoryPosts, {
        params: { category },
        props: { category },
        pageSize: POSTS_CONFIG.tagsPageConfig.size,
      })
    })
    .flat()
}

interface Props {
  page: Page<CollectionEntry<'posts'>>
  category: string
}

const { page, category } = Astro.props
const description = `Posts in category: ${category}`
---

<Layout title={category} {description}>
  <div class="relative z-[1] py-8 pb-10 px-6 sm:px-8">
    <div class="mb-12 md:mb-16">
      <div class="flex flex-col gap-3">
        <nav class="flex items-center gap-3 text-sm text-muted-foreground/80">
          <a href="/categories" class="group flex items-center gap-2 hover:text-primary transition-colors">
            <span class="icon-[ph--folder] w-4 h-4"></span>
            <span>文章分类</span>
          </a>
          <span class="text-muted-foreground/30">/</span>
          <span class="text-foreground/90">{category}</span>
        </nav>

        <div class="flex gap-2 justify-between">
          <h1 class="text-xl sm:text-3xl font-medium tracking-wide">
            {category}
          </h1>
          <div class="flex flex-col items-end justify-center gap-1 text-sm text-muted-foreground/70">
            <div class="flex items-center gap-2">
              <span class="icon-[ph--article-medium] w-4 h-4"></span>
              <span>{page.total} {page.total === 1 ? 'post' : 'posts'}</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="space-y-8 fade-up">
      <List posts={page.data} type={POSTS_CONFIG.tagsPageConfig.type} coverLayout={POSTS_CONFIG.tagsPageConfig?.coverLayout} />
    </div>

    <Pagination {page} baseUrl={`/categories/${category}`} class="mt-12" />
  </div>
</Layout>
